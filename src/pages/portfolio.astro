---
import PageLayout from "../layouts/PageLayout.astro";
import CaseStudyBlock from "../components/CaseStudyBlock.astro";
import Button from "../components/Button.astro";
import Github from "../components/icons/Github.astro";
import PortfolioItem from "../components/PortfolioItem.astro";
import { FEATURED_CASE_STUDIES } from "../data/featuredCaseStudies";
import { EXPERIMENTS } from "../data/experiments";

const meta = {
  title: "Work | Francisco Diaz Paccot",
  description:
    "Curated case studies and smaller experiments in web performance, product surfaces, and frontend platform work. Francisco Diaz Paccot.",
  logoUrl: "https://i.ibb.co/mFYW5QJ/new-logo-small.webp",
  url: "https://franciscodiazpaccot.dev/portfolio",
};
---

<PageLayout {meta} router="/portfolio">
  <div class="min-w-0 w-full max-w-6xl mx-auto px-4 sm:px-6 pt-12 sm:pt-16 md:pt-20 pb-8">
    <header class="max-w-2xl">
      <p
        class="text-[0.7rem] sm:text-xs font-medium tracking-[0.2em] uppercase text-[#e9552f]/85 mb-3"
      >
        Work
      </p>
      <h1
        class="eurostile text-3xl sm:text-4xl md:text-5xl text-zinc-50 font-semibold leading-tight tracking-tight"
      >
        A curated case library, not a project dump
      </h1>
      <p
        class="mt-5 sm:mt-6 text-sm sm:text-base text-zinc-500 font-light leading-[1.75]"
      >
        First: three flagship case studies. Below: experiments and
        one-off product work—still real constraints, with less narrative
        around them. Prefer depth over list length.
      </p>
    </header>
  </div>

  <section
    class="w-full min-w-0 max-w-6xl mx-auto px-4 sm:px-6 pb-12"
    aria-labelledby="flagship-heading"
  >
    <h2
      class="eurostile text-2xl sm:text-3xl text-zinc-100 font-semibold mb-2 flex items-baseline gap-2 flex-wrap"
      id="flagship-heading"
    >
      <span class="inline-block h-5 w-1 rounded-full bg-[#e9552f]/[0.65] shrink-0" aria-hidden="true"></span>
      Flagship work
    </h2>
    <p
      class="text-sm text-zinc-500 font-light max-w-2xl mb-12 sm:mb-16 leading-relaxed"
    >
      The same case studies you see on the home page—narrated as problem,
      solution, architecture, tradeoff, and outcome. One story per product.
    </p>
    {
      FEATURED_CASE_STUDIES.map((cs, i) => <CaseStudyBlock cs={cs} index={i} />)
    }
  </section>

  <section
    class="w-full min-w-0 max-w-6xl mx-auto px-4 sm:px-6 pb-16 sm:pb-20 border-t border-[#e9552f]/[0.12] pt-12 sm:pt-16"
    aria-labelledby="labs-heading"
  >
    <h2
      class="eurostile text-2xl sm:text-3xl text-zinc-100 font-semibold mb-2 flex items-baseline gap-2 flex-wrap"
      id="labs-heading"
    >
      <span class="inline-block h-5 w-1 rounded-full bg-[#e9552f]/[0.4] shrink-0" aria-hidden="true"></span>
      Experiments and labs
    </h2>
    <p
      class="text-sm sm:text-base text-zinc-500 font-light max-w-2xl leading-relaxed mb-10 sm:mb-12"
    >
      Smaller surfaces, spikes, and client work—useful to show range without
      pretending they all have the same depth as the featured row.
    </p>
    <div class="flex flex-col gap-20 sm:gap-24 md:gap-28">
      {
        EXPERIMENTS.map((item, index) => (
          <PortfolioItem
            isReverse={index % 2 !== 0}
            id={item.id}
            link={item.link}
            text={item.text}
            description={item.description}
            stack={[...item.stack]}
            logoUrl={item.logoUrl}
            logoWidth={item.logoWidth}
            logoHeight={item.logoHeight}
            bg={item.bg}
            github={"github" in item ? item.github : undefined}
            lighthouse={"lighthouse" in item ? item.lighthouse : undefined}
          />
        ))
      }
    </div>
  </section>

  <div
    class="flex justify-center pb-20 sm:pb-24 w-full min-w-0 min-h-px px-4"
  >
    <Button
      href="https://github.com/FranciscoDiazPaccot73"
      containerClass="w-full max-w-xs flex justify-center"
    >
      <span>GitHub profile</span>
      <span class="inline-flex ml-1.5 align-middle" aria-hidden="true"
        ><Github color="#16080e" height={20} width={20} />
      </span>
    </Button>
  </div>
</PageLayout>

<script is:inline>
  window.addEventListener("scroll", () => {
    const h = document.body.offsetHeight - window.innerHeight;
    if (h <= 0) return;
    document.body.style.setProperty("--scroll", String(window.scrollY / h));
  });
</script>
