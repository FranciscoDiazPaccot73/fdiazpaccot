---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

import PageLayout from "../../layouts/PageLayout.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import ChevronLeft from "../../components/icons/ChevronLeft.astro";
import LanguageSelect from "../../components/LanguageSelect.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;

const hasLanguageSelector = (post.data.languages?.length || 0) > 1;

const { Content } = await post.render();

const meta = {
  title: `${post.data.title} | Writing | Francisco Diaz Paccot`,
  description: post.data.description,
  logoUrl: "https://i.ibb.co/HXYhwjK/blog-portrait.png",
  url: "https://franciscodiazpaccot.dev",
};
---

<PageLayout {meta} router={`/blog/${post.slug}`}>
  <div
    class="reading-progress fixed top-0 left-0 h-[2.5px] z-[100] will-change-[width] motion-reduce:hidden bg-[#e9552f] shadow-[0_0_12px_rgba(233,85,47,0.4)]"
    style="width: calc((var(--scroll, 0) * 100%))"
    aria-hidden="true"
  >
  </div>
  <article
    class="article-surface w-full min-w-0 max-w-3xl mx-auto px-4 sm:px-5 pb-20 sm:pb-28 antialiased"
  >
    {hasLanguageSelector && <LanguageSelect slug={`/blog/${post.slug}`} />}
    <div class="pt-8 sm:pt-10">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-[#e9552f]/85 transition mb-6 sm:mb-8"
        aria-label="Back to all writing"
      >
        <span class="inline-block scale-100"><ChevronLeft /></span>
        <span>Writing</span>
      </a>
      <h1
        class="eurostile text-2xl sm:text-3xl md:text-[2rem] leading-tight text-zinc-100 font-semibold m-0"
      >
        {post.data.title}
      </h1>
      <div
        class="mt-3 flex flex-wrap items-baseline gap-x-3 gap-y-1 text-sm text-zinc-500"
      >
        <FormattedDate
          locale="en-US"
          date={post.data.pubDate}
          className="text-zinc-500 m-0"
        />
        {
          post.data.readingTime && (
            <span class="text-zinc-600">~{post.data.readingTime} min read</span>
          )
        }
        {
          post.data.updatedDate && (
            <span class="text-zinc-600 w-full sm:w-auto text-sm">
              Last updated
              <FormattedDate
                locale="en-US"
                date={post.data.updatedDate}
                className="text-zinc-600 ml-1 m-0 inline"
              />
            </span>
          )
        }
      </div>
    </div>

    {
      post.data.image && (
        <div class="mt-6 sm:mt-8 w-full -mx-1 max-w-4xl overflow-hidden rounded-xl sm:rounded-2xl">
          <img
            class="w-full h-auto object-cover"
            width={800}
            height={450}
            src={post.data.image}
            alt={post.data.title}
          />
        </div>
      )
    }
    {
      post.data.description && (
        <p
          class="eurostile text-base sm:text-lg text-zinc-500 font-light leading-relaxed mt-6 sm:mt-7 border-l-2 border-l-[#e9552f]/[0.35] pl-4 m-0"
        >
          {post.data.description}
        </p>
      )
    }

    <div
      class="article-body prose-article mt-8 sm:mt-10
        prose prose-invert prose-sm sm:prose-base max-w-none
        prose-headings:font-sans prose-headings:font-medium prose-headings:tracking-tight
        prose-h1:text-2xl prose-h2:mt-10 prose-h2:text-xl
        prose-h2:border-b prose-h2:border-zinc-800 prose-h2:pb-2
        prose-p:text-zinc-400 prose-p:leading-[1.75] prose-p:font-light
        prose-a:text-[#e9552f]/[0.88] prose-a:underline prose-a:decoration-[#e9552f]/[0.35]
        prose-a:underline-offset-2 hover:prose-a:text-[#e9552f] hover:prose-a:decoration-[#e9552f]/[0.6]
        prose-code:text-zinc-300 prose-code:before:content-none prose-code:after:content-none
        prose-pre:bg-zinc-900/80 prose-pre:border prose-pre:border-zinc-800
        prose-li:text-zinc-400
        [&_h1]:!text-2xl sm:[&_h1]:!text-3xl
        [&_h2]:!text-xl
        [&_h3]:!text-lg
      "
    >
      <Content />
    </div>
    {
      (post.data.mediumBlog || post.data.devBlog) && (
        <div class="mt-10 pt-6 border-t border-zinc-800/80">
          <p class="text-xs uppercase tracking-wider text-zinc-500 mb-3 m-0">
            Also on
          </p>
          <div class="flex flex-wrap gap-2">
                {post.data.mediumBlog && (
                  <a
                    href={post.data.mediumBlog}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="px-2.5 py-1.5 text-xs text-zinc-300 rounded border border-zinc-700/80 hover:border-zinc-500 transition"
                  >
                    Medium
                  </a>
                )}
            {post.data.devBlog && (
              <a
                href={post.data.devBlog}
                target="_blank"
                rel="noopener noreferrer"
                class="px-2.5 py-1.5 text-xs text-zinc-300 rounded border border-zinc-700/80 hover:border-zinc-500 transition"
              >
                dev.to
              </a>
            )}
          </div>
        </div>
      )
    }
  </article>
</PageLayout>

<script is:inline>
  window.addEventListener("scroll", () => {
    const h = document.body.offsetHeight - window.innerHeight;
    if (h <= 0) return;
    document.body.style.setProperty("--scroll", String(window.scrollY / h));
  });
</script>

<style>
  :global(.article-surface) {
    max-width: 100%;
  }
</style>
