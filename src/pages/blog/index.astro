---
import { getCollection } from "astro:content";

import PageLayout from "../../layouts/PageLayout.astro";

import Content from "../../components/blog/Content";

const meta = {
  title: "Writing | Francisco Diaz Paccot",
  description:
    "Notes on web performance, systems, and frontend practice — Francisco Diaz Paccot.",
  logoUrl: "https://i.ibb.co/HXYhwjK/blog-portrait.png",
  url: "https://franciscodiazpaccot.dev/blog",
};

const blogs = await getCollection(
  "blog",
  ({ data }) => data.published === true
);

const blogsEs = blogs.filter((post) => post.data.blogLanguage === "es");
const blogsEn = blogs.filter((post) => post.data.blogLanguage === "en");

const idsUsed: number[] = [];

const dataPosts = blogsEn.map((blog) => {
  idsUsed.push(blog.data.id);

  return blog;
});

blogsEs.forEach((blog) => {
  if (idsUsed.includes(blog.data.id)) {
    return;
  }

  idsUsed.push(blog.data.id);

  dataPosts.push(blog);
});

const posts: any = {};
let years: number[] = [];

dataPosts.forEach((post: any) => {
  const pubDate = new Date(post.data.pubDate);
  const timestamp = pubDate.getTime();
  post.timestamp = timestamp;

  const year = pubDate.getFullYear();

  if (posts[year]) {
    posts[year].push(post);

    posts[year].sort((a: any, b: any) => b.timestamp - a.timestamp);
  } else {
    posts[year] = [post];
    years = [...new Set([...years, year])];
  }
});

years.sort((a, b) => b - a);
---

<PageLayout {meta} router="/blog">
  <section
    class="w-full min-w-0 max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16 md:py-20"
    aria-labelledby="writing-page-title"
  >
    <div class="max-w-2xl">
      <p
        class="text-[0.7rem] sm:text-xs font-medium tracking-[0.2em] uppercase text-[#e9552f]/85 mb-3"
      >
        Journal
      </p>
      <h1
        class="eurostile text-3xl sm:text-4xl md:text-5xl text-zinc-100 font-semibold tracking-tight"
        id="writing-page-title"
      >
        Writing
      </h1>
      <p
        class="mt-4 sm:mt-5 text-sm sm:text-base text-zinc-500 font-light leading-[1.75]"
      >
        A running log on performance, systems, and frontend
        practice—enough context to be useful, not a dump of every draft.
      </p>
    </div>
    <Content client:load years={years} posts={posts} />
  </section>
</PageLayout>
