---
import PageLayout from "../../layouts/PageLayout.astro";
import AboutManifesto from "../../components/about/AboutManifesto.astro";
import AboutTimeline from "../../components/AboutTimeline.astro";
import AboutHobies from "../../components/AboutHobies.astro";

const meta = {
  title: "About | Francisco Diaz Paccot",
  description:
    "Engineering practice, principles, and track record — senior frontend, performance, platform, and product architecture. Francisco Diaz Paccot.",
  logoUrl: "https://i.ibb.co/mFYW5QJ/new-logo-small.webp",
  url: "https://franciscodiazpaccot.dev/about",
};
---

<PageLayout {meta} router="/about">
  <AboutManifesto />
  <div
    class="max-w-6xl mx-auto w-full h-px bg-zinc-800/60 my-4"
    aria-hidden="true"
  >
  </div>
  <AboutTimeline />
  <AboutHobies />
</PageLayout>

<script is:inline>
  window.addEventListener("scroll", () => {
    const calculation =
      window.scrollY / (document.body.offsetHeight - window.innerHeight);
    document.body.style.setProperty("--scroll", String(calculation));

    const me = document.getElementById("me-about");
    if (window.scrollY >= 50 && me && !me.classList.contains("show")) {
      me.classList.add("show");
    }
  });
</script>
