<section
  class="w-full relative px-4 sm:px-6 py-20 sm:py-28 md:py-32"
  aria-labelledby="contact-cta-heading"
>
  <div
    class="max-w-6xl mx-auto rounded-2xl sm:rounded-3xl px-6 sm:px-10 md:px-14 py-12 sm:py-16 md:py-20 text-center relative overflow-hidden cta-surface"
  >
    <div
      class="absolute inset-0 pointer-events-none opacity-[0.35] cta-mesh"
      aria-hidden="true"
    >
    </div>
    <div class="relative z-10 max-w-2xl mx-auto">
      <p
        class="text-[0.7rem] sm:text-xs font-medium tracking-[0.2em] uppercase text-[#e9552f]/85 mb-4"
      >
        Work together
      </p>
      <h2
        id="contact-cta-heading"
        class="eurostile text-2xl sm:text-3xl md:text-4xl text-zinc-100 font-semibold tracking-tight leading-tight mb-4"
      >
        Open to senior frontend, platform, and product-facing roles.
      </h2>
      <p
        class="text-zinc-400 text-sm sm:text-base leading-relaxed mb-8 sm:mb-10 font-light"
      >
        If you are scaling a web product and care about performance,
        maintainability, and how engineering decisions show up in the
        business, I would like to hear from you.
      </p>
      <div
        class="flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:gap-4"
      >
        <a
          href="mailto:fran.diazpaccot@gmail.com"
          class="inline-flex items-center justify-center rounded-full px-6 sm:px-7 py-3.5 text-sm font-medium text-[#0a0a0b] bg-[#e9552f] hover:bg-[#f06a45] shadow-[0_0_24px_rgba(233,85,47,0.2)] transition-colors duration-200"
        >
          Email
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-full px-6 sm:px-7 py-3.5 text-sm font-medium text-zinc-200 border border-[#e9552f]/30 hover:border-[#e9552f]/50 hover:text-[#e9552f]/90 transition-colors duration-200"
        >
          Contact page
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-surface {
    background: linear-gradient(145deg, #141416 0%, #0c0c0d 100%);
  }
  .cta-mesh {
    background: radial-gradient(
        ellipse 80% 50% at 20% 0%,
        rgba(233, 85, 47, 0.18),
        transparent 50%
      ),
      radial-gradient(
        ellipse 60% 40% at 100% 100%,
        rgba(233, 85, 47, 0.1),
        transparent 45%
      );
  }
</style>
