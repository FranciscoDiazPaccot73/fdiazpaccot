---
import PerformanceMetrics from "./PerformanceMetrics";
import Github from "./icons/Github.astro";

const {
  link,
  text,
  logoUrl,
  stack,
  description,
  logoWidth,
  logoHeight,
  id,
  github,
  bg,
  lighthouse,
  isReverse = false,
} = Astro.props;

const hasLogo = Boolean(logoUrl);
const imageProps = hasLogo
  ? { width: logoWidth, height: logoHeight, src: logoUrl, alt: text }
  : null;

const startClass = isReverse ? "md:col-start-1" : "";
---

<article
  class="min-w-0 flex flex-col-reverse gap-6 md:gap-8 md:items-start md:grid-cols-12 md:grid md:gap-x-8"
>
  <div
    class="min-w-0 col-span-5 col-start-1 row-start-1 relative md:mt-0"
  >
    <h3
      class="eurostile m-0 text-zinc-100 text-xl sm:text-2xl md:text-3xl font-semibold"
    >
      {text}
    </h3>
    <p
      class="text-zinc-500 text-sm sm:text-base mt-3 font-light leading-relaxed max-w-prose"
    >
      {description}
    </p>
    {
      stack?.length > 0 ? (
        <p
          class="mt-4 text-xs text-zinc-500 font-normal tracking-wide"
        >
          <span class="text-[#e9552f]/70">Stack · </span>
          {stack.join(" · ")}
        </p>
      ) : null
    }
    {lighthouse && id ? (
      <div class="mt-5">
        <PerformanceMetrics
          client:visible
          id={id}
          info={lighthouse}
          label={`${text} — Lighthouse (reference)`}
        />
      </div>
    ) : null}
    {github ? (
      <a
        aria-label={`${text} on GitHub`}
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="absolute top-0 right-0 p-1 rounded-md z-[6] md:top-0 md:right-0 text-zinc-600 hover:text-zinc-300"
      >
        <Github width={24} height={24} color="#a1a1aa" />
      </a>
    ) : null}
  </div>
  <div class:list={["min-w-0 flex-auto md:row-start-1 md:col-span-7", startClass]}>
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="group block rounded-xl overflow-hidden"
    >
      {bg ? (
        <div
          class="relative aspect-[16/9] sm:aspect-[2/1] w-full max-h-[320px] bg-zinc-900/20 ring-1 ring-zinc-800/60 group-hover:ring-zinc-700/90 transition duration-500"
        >
          <img
            src={bg}
            alt=""
            class="w-full h-full object-cover opacity-90 transition duration-500 group-hover:scale-[1.01]"
          />
          {hasLogo && imageProps ? (
            <img
              {...imageProps}
              class="hidden md:block absolute w-8 h-8 sm:w-10 sm:h-10 top-3 left-3 sm:top-5 sm:left-5 object-contain transition duration-500 ease-out group-hover:scale-105"
            />
          ) : null}
        </div>
      ) : (
        <div
          class="flex w-full min-h-[120px] md:min-h-[200px] items-center justify-center rounded-xl bg-zinc-900/30 ring-1 ring-zinc-800/60"
        >
          {hasLogo && imageProps ? (
            <img class="block w-20 h-20" {...imageProps} />
          ) : (
            <p class="eurostile text-zinc-400 text-lg sm:text-2xl px-4 text-center">
              {text}
            </p>
          )}
        </div>
      )}
    </a>
  </div>
</article>
