---
// import Button from "../components/Button.astro";
import TimelineItem from "./AboutTimelineSection.astro";

const steps = [
  {
    job: `Frontend Software Engineer`,
    title: "Deel",
    duration: "July 2024",
    link: "https://www.deel.com/",
    logo: "/deel-logo.webp",
    tId: "deel",
    present: true,
    description: [
      "Part of the org chart team, developing and improving its performance so users can rely on it in their daily work.",
      "Part of the team building Workforce Planning—a product that helps customers plan their organizations and is positioned to drive significant revenue for Deel.",
      "Leading the initial work on the Ashby integration, giving customers a better way to connect new openings with their existing tools.",
    ],
  },
  {
    job: `Sr. Software Engineer`,
    title: "Strike",
    duration: "May 2023 to July 2024 (1yr 2mo)",
    link: "https://strike.sh",
    logo: "/strike-logo.ico",
    tId: "strike",
    description: [
      "As a prominent member of the team responsible for conceiving and bringing to life our company's innovative landing page, I have played a pivotal role in creating a fresh and rejuvenated image.",
      "I have taken on the full responsibility for the comprehensive development of the new pentest creation workflow, the cornerstone of our company and the essential tool to meet the needs of all our valuable clients.",
    ],
  },
  {
    job: `Sr. Front-End Software Engineer`,
    title: "Mercado Libre",
    duration: "Dec 2019 to May 2023 (3yr 5mo)",
    link: "https://mercadolibre.com",
    logo: "/meli-logo.png",
    tId: "meli",
    description: [
      "Played a key role in the development of marketing tools for Mercado Shops from the ground up, contributing to the project's initial stages and ensuring a successful outcome.",
      `Designed and developed the frontend of the "Central de Promociones," a critical application that enables sellers on the Mercado Libre platform to create product offers and upload items in bulk to their promotions. This project involved working with large datasets and complex business logic to provide a seamless experience for users.`,
      `Contributed to the development of components in Andes, the company's internal UI library, improving the consistency and usability of the platform's interfaces.`,
      `Played a critical role in the formation of the Frontend Performance team, working on projects to optimize the performance of web applications and ensure they load quickly and efficiently.`,
      `Collaborated with the Benefits initiative enablings team to provide technical support and develop tools that automated the collection of performance metrics. These efforts allowed for quick identification and resolution of issues, resulting in improved frontend stability and overall user experience.`,
    ],
  },
  {
    job: `Ssr. Full-Stack developer`,
    title: "Serfe",
    duration: "Oct 2018 to Dec 2019 (1yr 3mo)",
    link: "https://serfe.com",
    logo: "/serfe-logo2.png",
    tId: "serfe",
    description: [
      `Conducted maintenance of a legacy mobile application built with PhoneGap and Angular 1.2, ensuring its continued usability and stability.`,
      `Led a team of 3 developers in building a new React Native mobile app, overseeing the project's entire lifecycle from conception to deployment.`,
      `Contributed to the development of the web platform for the application, utilizing React to create a modern and user-friendly interface.`,
      `Worked as a part of the backend development team for the application, utilizing Node.js to develop robust and scalable APIs and services that supported the frontend application.`,
    ],
  },
];
---

<section
  class="px-4 sm:px-6 py-14 sm:py-20 relative text-zinc-300 max-w-6xl mx-auto w-full"
  aria-labelledby="track-record-heading"
>
  <p
    class="text-[0.7rem] sm:text-xs font-medium tracking-[0.2em] uppercase text-[#e9552f]/85 mb-3"
  >
    History
  </p>
  <h2
    class="eurostile text-2xl sm:text-3xl font-semibold text-zinc-100 mb-3"
    id="track-record-heading"
  >
    Where the practice met production
  </h2>
  <p
    class="text-sm sm:text-base text-zinc-500 font-light max-w-2xl leading-relaxed mb-12 sm:mb-16"
  >
    A concise record of the environments where the philosophy above was
    pressure-tested. Bullets are outcomes, not a job description.
  </p>
  <div class="about-tl relative w-full min-w-0">
    <!-- Línea vertical continua: un solo eje, los iconos la tapan (z-index + anillo) -->
    <div class="about-tl-spine" aria-hidden="true"></div>
    <ol class="relative z-[1] m-0 list-none p-0" role="list">
      {
        steps.map((item) => {
          const { tId: _tid, ...itemProps } = item;
          return <TimelineItem {...itemProps} />;
        })
      }
    </ol>
    <div
      class="relative z-[1] -mt-0.5 flex w-full min-w-0 flex-row gap-3 sm:gap-4"
    >
      <div class="flex w-8 shrink-0 flex-col items-center justify-center sm:w-9" aria-hidden="true">
        <div
          class="relative z-20 h-2.5 w-2.5 shrink-0 rounded-full border border-[#e9552f]/45 bg-zinc-950/95 ring-[3px] ring-[#0a0a0b] shadow-sm"
          title="Start of career (chronological, oldest entry above)"
        />
      </div>
      <p
        class="m-0 pt-0.5 text-[0.7rem] font-medium uppercase tracking-[0.2em] text-zinc-500 sm:text-xs"
      >
        <span class="text-[#e9552f]/85">·</span> Career start
      </p>
    </div>
  </div>
  <!-- <Button
    href="docs/FranciscoDiazPaccot-resume.pdf"
    download="Francisco Diaz Paccot - Resume"
  >
    Download Resume
  </Button> -->
</section>

<style is:global>
  .about-tl {
    position: relative;
    z-index: 0;
  }
  .about-tl-spine {
    position: absolute;
    z-index: 0;
    pointer-events: none;
    top: 1rem;
    bottom: 0.45rem;
    width: 1.5px;
    border-radius: 9999px;
    /* Centered on the icon column: w-8 = 1rem, sm:w-9 = 1.125rem from column origin */
    left: calc(1rem - 0.75px);
    background: linear-gradient(
      180deg,
      rgba(233, 85, 47, 0.92) 0%,
      rgba(233, 85, 47, 0.38) 10%,
      rgba(82, 82, 91, 0.92) 40%,
      rgba(63, 63, 70, 0.96) 100%
    );
  }
  @media (min-width: 640px) {
    .about-tl-spine {
      left: calc(1.125rem - 0.75px);
    }
  }
</style>
