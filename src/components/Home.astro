---
import { Image } from "astro:assets";
---

<section
  class="home-hero w-full relative flex flex-col justify-end sm:justify-center min-h-[calc(100dvh-72px)] min-h-[500px] px-4 sm:px-6 pt-8 pb-20 sm:pb-16 overflow-hidden"
  aria-label="Introduction"
>
  <div class="home-hero__bg" aria-hidden="true"></div>
  <div class="home-hero__grain" aria-hidden="true"></div>

  <div class="relative z-10 max-w-6xl w-full mx-auto">
    <div
      class="max-w-3xl motion-safe:animate-home-enter motion-reduce:opacity-100"
    >
      <p
        class="text-[0.65rem] sm:text-xs font-medium tracking-[0.22em] uppercase text-[#e9552f]/80 mb-4 sm:mb-5"
      >
        Francisco Diaz Paccot
      </p>
      <h1
        class="eurostile text-[2.125rem] sm:text-5xl md:text-6xl lg:text-[3.35rem] xl:text-6xl font-semibold text-zinc-50 leading-[1.05] tracking-tight"
      >
        Senior frontend engineering at the intersection of
        <span class="text-[#e9552f]"> product, performance,</span> and
        <span class="text-zinc-200"> platform.</span>
      </h1>
      <p
        class="mt-6 sm:mt-8 text-base sm:text-lg text-zinc-400 font-light leading-relaxed max-w-xl"
      >
        I design and build web experiences where architecture decisions
        show up in metrics, velocity, and how the product feels under real
        load, not just in a demo environment.
      </p>
      <div
        class="mt-10 sm:mt-12 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6"
      >
        <a
          href="#case-studies"
          class="group inline-flex items-center gap-2 text-sm font-medium text-zinc-100 border-b border-transparent hover:border-[#e9552f]/60 text-[#e9552f]/90 hover:text-[#e9552f] transition-colors w-fit"
        >
          <span>Selected work</span>
          <span
            class="inline-block translate-x-0 group-hover:translate-x-0.5 transition-transform"
            aria-hidden="true"
            >→</span
          >
        </a>
        <span
          class="hidden sm:block w-px h-4 bg-[#e9552f]/20 shrink-0"
          aria-hidden="true"
        >
        </span>
        <a
          href="/blog"
          class="text-sm font-medium text-zinc-500 hover:text-[#e9552f]/85 transition-colors"
        >
          Writing on performance
        </a>
      </div>
    </div>

    <div
      class="mt-16 sm:mt-20 md:mt-0 md:absolute md:right-4 md:top-1/2 md:-translate-y-1/2 md:w-auto flex justify-start md:justify-end motion-safe:animate-home-enter-delayed motion-reduce:opacity-100"
    >
      <div
        class="relative rounded-2xl p-[1px] bg-gradient-to-br from-zinc-700/50 to-zinc-900/0 shadow-2xl shadow-black/40"
      >
        <div
          class="rounded-2xl bg-zinc-950/80 p-3 sm:p-4 backdrop-blur-sm ring-1 ring-zinc-800/60"
        >
          <Image
            width={120}
            height={120}
            loading="eager"
            src="/logo-small.webp"
            alt="Francisco Diaz Paccot"
            class="w-20 h-20 sm:w-[120px] sm:h-[120px] opacity-95"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .home-hero {
    background: var(--black);
  }
  .home-hero__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(
        ellipse 120% 80% at 15% 10%,
        rgba(233, 85, 47, 0.09) 0%,
        transparent 50%
      ),
      radial-gradient(
        ellipse 90% 60% at 85% 50%,
        rgba(80, 80, 100, 0.08) 0%,
        transparent 45%
      ),
      linear-gradient(180deg, #0a0a0b 0%, #08080a 100%);
    pointer-events: none;
  }
  .home-hero__grain {
    position: absolute;
    inset: 0;
    opacity: 0.25;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes home-enter {
      from {
        opacity: 0;
        transform: translateY(0.5rem);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .animate-home-enter {
      animation: home-enter 0.7s ease-out both;
    }
    .animate-home-enter-delayed {
      animation: home-enter 0.7s 0.12s ease-out both;
    }
  }
</style>
