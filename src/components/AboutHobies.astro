---
import { PICTURES } from "../pages/about/pictures";
import BentoGrid from "./BentoGrid.astro";
import ImagePreview from "./ImagePreview.astro";

const elements = [
  PICTURES.mcSF,
  PICTURES.bridgeAndSculturebnw,
  PICTURES.faroSF,
  PICTURES.graffiti,
];
---

<div
  class="px-4 sm:px-6 py-14 sm:py-20 mt-0 flex flex-col gap-6 border-t border-zinc-800/60 max-w-6xl w-full mx-auto"
>
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
    <div>
      <p
        class="text-[0.7rem] sm:text-xs font-medium tracking-[0.2em] uppercase text-zinc-500 mb-2"
      >
        Off keyboard
      </p>
      <h2
        class="eurostile text-2xl sm:text-3xl text-zinc-100 font-semibold"
      >
        Field notes
      </h2>
    </div>
    <a
      href="/about/gallery"
      class="text-sm font-medium text-zinc-500 hover:text-zinc-200 transition-colors w-fit"
    >
      Full gallery
      <span class="ml-0.5" aria-hidden="true">→</span>
    </a>
  </div>
  <p
    class="text-sm sm:text-base text-zinc-500 font-light max-w-xl leading-relaxed mb-2"
  >
    I carry a camera the way I carry a profiler: to notice what is easy to
    walk past. Same taste for light and constraint shows up in product work.
  </p>
  <ImagePreview>
    <BentoGrid elements={elements} imgCustomClass="preview-image" />
  </ImagePreview>
</div>
