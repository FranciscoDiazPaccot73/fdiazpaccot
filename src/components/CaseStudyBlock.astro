---
import { Image } from "astro:assets";
import type { CaseStudy } from "../data/featuredCaseStudies";

export interface Props {
  cs: CaseStudy;
  index: number;
}

const { cs, index: i } = Astro.props;
---

<article
  class:list={[
    "case-block grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start",
    { "mt-20 sm:mt-24 md:mt-28": i > 0 },
  ]}
>
  <div
    class:list={[
      "min-w-0 lg:col-span-5",
      { "lg:order-2 lg:pl-4": i % 2 === 1, "lg:pr-4": i % 2 === 0 },
    ]}
  >
    <a
      href={cs.link}
      target="_blank"
      rel="noopener noreferrer"
      class="block group"
      aria-label={cs.linkLabel}
    >
      <div
                class="overflow-hidden rounded-xl bg-zinc-900/40 ring-1 ring-zinc-800/60 transition duration-500 group-hover:ring-[#e9552f]/[0.3]"
      >
        <Image
          src={cs.image}
          alt={`${cs.title} product screenshot`}
          width={800}
          height={520}
          class="w-full h-auto object-cover aspect-[16/10] sm:aspect-[4/3] transition duration-700 group-hover:scale-[1.02] max-w-full"
          style={{ objectFit: "cover" }}
          loading="lazy"
        />
      </div>
    </a>
    <a
      href={cs.link}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 inline-flex text-sm font-medium text-zinc-500 hover:text-[#e9552f]/85"
    >
      {cs.title} — live site
      <span class="ml-1.5" aria-hidden="true">↗</span>
    </a>
  </div>

  <div
    class:list={[
      "min-w-0 lg:col-span-7 space-y-6",
      { "lg:order-1": i % 2 === 1 },
    ]}
  >
    <div>
      <p class="text-xs font-medium tracking-wider text-[#e9552f]/80 uppercase">
        {cs.kicker}
      </p>
      <h3
        class="eurostile mt-2 text-2xl sm:text-3xl font-semibold text-zinc-100 tracking-tight"
      >
        {cs.title}
      </h3>
    </div>

    <div
      class="space-y-4 text-sm sm:text-base text-zinc-400 font-light leading-relaxed"
    >
      <p>
        <span class="text-[#e9552f]/80 font-medium">Problem · </span>
        {cs.problem}
      </p>
      <p>
        <span class="text-[#e9552f]/80 font-medium">Solution · </span>
        {cs.solution}
      </p>
    </div>

    <div class="space-y-5 pt-2">
      <div>
        <p
          class="text-[0.65rem] uppercase tracking-[0.15em] text-[#e9552f]/55 mb-1.5"
        >
          Architecture
        </p>
        <p class="text-sm text-zinc-300 font-light leading-relaxed">
          {cs.architecture}
        </p>
      </div>
      <div>
        <p
          class="text-[0.65rem] uppercase tracking-[0.15em] text-[#e9552f]/55 mb-1.5"
        >
          Tradeoffs
        </p>
        <p class="text-sm text-zinc-300 font-light leading-relaxed">
          {cs.tradeoffs}
        </p>
      </div>
      <div>
        <p
          class="text-[0.65rem] uppercase tracking-[0.15em] text-[#e9552f]/55 mb-1.5"
        >
          Outcomes
        </p>
        <p class="text-sm text-zinc-300 font-light leading-relaxed">
          {cs.outcomes}
        </p>
      </div>
    </div>
  </div>
</article>
