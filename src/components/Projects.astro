---
import CaseStudyBlock from "./CaseStudyBlock.astro";
import { FEATURED_CASE_STUDIES } from "../data/featuredCaseStudies";
---

<section
  id="case-studies"
  class="w-full scroll-mt-24 sm:scroll-mt-28"
  aria-labelledby="case-studies-heading"
>
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 sm:pt-20 md:pt-28 pb-8 sm:pb-10"
  >
    <div class="max-w-2xl">
      <p
        class="text-[0.7rem] sm:text-xs font-medium tracking-[0.2em] uppercase text-[#e9552f]/85 mb-3"
      >
        Case studies
      </p>
      <h2
        id="case-studies-heading"
        class="eurostile text-3xl sm:text-4xl font-semibold text-zinc-50 tracking-tight"
      >
        How engineering choices surface in the product
      </h2>
      <p
        class="mt-4 sm:mt-5 text-sm sm:text-base text-zinc-500 font-light leading-relaxed"
      >
        A sample of work where architecture, performance, and product tradeoffs
        are explicit. For a broader list, use the full portfolio.
      </p>
      <a
        href="/portfolio"
        class="inline-block mt-6 sm:mt-7 text-sm font-medium text-zinc-400 hover:text-[#e9552f]/90 border-b border-zinc-600 border-dotted hover:border-[#e9552f]/40 transition-colors w-fit"
      >
        View full portfolio
      </a>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 pb-16 sm:pb-20 md:pb-28">
    {FEATURED_CASE_STUDIES.map((cs, i) => <CaseStudyBlock cs={cs} index={i} />)}
  </div>
</section>
