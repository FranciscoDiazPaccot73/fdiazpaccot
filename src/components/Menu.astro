---
import Home from "./icons/Home.astro";
import Info from "./icons/Info.astro";
import Portfolio from "./icons/Portfolio.astro";
import Contact from "./icons/Contact.astro";

const { router } = Astro.props;

const settings = {
  home: {
    name: "Home",
    link: "/",
  },
  about: {
    name: "About me",
    link: "/about",
  },
  portfolio: {
    name: "Portfolio",
    link: "/portfolio",
  },
  contact: {
    name: "Contact",
    link: "/contact",
  },
};
---

<div
  class="md:hidden fixed inset-x-0 z-20 flex justify-center pointer-events-none mobile-nav-offset"
>
  <nav
    class="pointer-events-auto flex w-[92%] max-w-md items-center justify-between rounded-full border border-white/[0.08] bg-[rgba(20,20,20,0.75)] px-1.5 shadow-[0_8px_40px_rgba(0,0,0,0.35)] backdrop-blur-xl h-[68px]"
    aria-label="Mobile navigation"
  >
    {
      ["home", "about", "portfolio", "contact"].map((value) => {
        // @ts-ignore
        const setting = settings[value] ?? {};
        const iconColor = setting.link === router ? "var(--orange)" : "#c9c9c9";

        return (
          <a
            href={setting.link}
            class="flex flex-1 items-center justify-center min-h-[44px] min-w-[44px]"
            aria-label={`${setting.name} page`}
          >
            <span
              class:list={[
                "mobile-nav-item flex h-11 w-11 items-center justify-center rounded-full transition-all duration-250 ease-out active:scale-95",
                { "mobile-nav-item--active": setting.link === router },
              ]}
            >
              <Home
                width={24}
                height={24}
                hidden={value !== "home"}
                color={iconColor}
              />
              <Info
                width={24}
                height={24}
                hidden={value !== "about"}
                color={iconColor}
              />
              <Portfolio
                width={24}
                height={24}
                hidden={value !== "portfolio"}
                color={iconColor}
              />
              <Contact
                width={24}
                height={24}
                hidden={value !== "contact"}
                color={iconColor}
              />
              <span class="hidden">{setting.name}</span>
            </span>
          </a>
        );
      })
    }
  </nav>
</div>

<style>
  .mobile-nav-offset {
    bottom: calc(12px + env(safe-area-inset-bottom, 0px));
  }

  .mobile-nav-item {
    background-color: transparent;
  }

  .mobile-nav-item--active {
    background-color: rgba(255, 255, 255, 0.12);
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-nav-item {
      transition: none;
    }

    .mobile-nav-item:active {
      transform: none;
    }
  }
</style>
